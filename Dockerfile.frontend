FROM node:18-slim

WORKDIR /app

# Frontend app lives in ./frontend (npm workspace package)
COPY frontend/package*.json ./

RUN npm install

COPY frontend/ ./

# Production build: avoids stale `next dev` route bundles (old POST /api/crew).
ENV NODE_ENV=production
RUN npm run build

EXPOSE 3000

CMD ["npm", "run", "start"]
